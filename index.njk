      <p class="section-label" style="color: rgba(255, 255, 255, 0.55)">Let's talk</p>
      <h2 class="section-title light">What Could Your Business<br />Look Like with Fished?</h2>
      <p style="color: rgba(255, 255, 255, 0.6); margin-top: 14px; max-width: 480px; margin-inline: auto; font-size: 15px">
        Book a no-obligation chat with one of our sales representatives.
      </p>
    </div>
    {% include "components/contact-form.njk" %}
  </div>
</section>
<script>
  (function () {
    const e = document.getElementById("testimonial-carousel");
    if (!e) return;
    const o = Array.from(e.querySelectorAll(".testimonial-slot"));
    if (o.length < 2) return;
    const l = o.map((t) => Array.from(t.querySelectorAll(".testimonial-card"))),
      r = [0, 0];
    let s = 0;
    l.forEach((t) => t[0].classList.add("active"));
    function a(t) {
      const c = l[t];
      c[r[t]].classList.remove("active");
      r[t] = (r[t] + 1) % c.length;
      c[r[t]].classList.add("active");
      const slotEl = o[t];
      slotEl.classList.remove("pinging");
      void slotEl.offsetWidth;
      slotEl.classList.add("pinging");
    }
    document.getElementById("testimonial-carousel").addEventListener("animationend", (ev) => {
      ev.target.closest(".testimonial-slot") && ev.target.closest(".testimonial-slot").classList.remove("pinging");
    });
    setInterval(() => {
      (a(s), (s = 1 - s));
    }, 5e3);
  })();
  const n = document.querySelector(".nav"),
    d = document.querySelector("#contact");
  window.addEventListener("scroll", () => {
    d && window.scrollY >= d.offsetTop
      ? n.classList.add("hidden")
      : (n.classList.remove("hidden"),
        n.classList.toggle("scrolled", window.scrollY > 40));
  });
  function fmtPhone(v) {
    const d = v.replace(/\D/g, "");
    if (d.length === 10)
      return "+" + d.slice(0, 2) + " " + d.slice(2, 5) + " " + d.slice(5, 7) + " " + d.slice(7, 10);
    if (d.length === 8) return "+47 " + d.slice(0, 3) + " " + d.slice(3, 5) + " " + d.slice(5, 8);
    return v.trim();
  }
  function fmtTitle(v) {
    return v.trim().replace(/\s+/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
  }
  function fmtMsg(v) {
    return v.trim().replace(/^[a-z]/, (c) => c.toUpperCase()).replace(/([.!?]\s+)([a-z])/g, (_, p, c) => p + c.toUpperCase());
  }
  window.handleFormSubmit = async function (event) {
    event.preventDefault();
    const f = event.target,
      btn = f.querySelector('button[type="submit"]'),
      fb = document.getElementById("form-feedback"),
      data = {
        name: fmtTitle(f.elements.name.value),
        phone: fmtPhone(f.elements.phone.value),
        email: f.elements.email.value.trim().toLowerCase(),
        company: fmtTitle(f.elements.company.value),
        message: fmtMsg(f.elements.message.value),
      };
    btn.disabled = true;
    btn.textContent = "Sending\u2026";
    fb.style.display = "none";
    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error("Request failed");
      fb.textContent = "Thank you! We will be in touch shortly.";
      fb.style.color = "var(--blue)";
      fb.style.display = "block";
      f.reset();
    } catch (e) {
      fb.textContent = "Something went wrong. Please try again or email us directly.";
      fb.style.color = "#c0392b";
      fb.style.display = "block";
    } finally {
      btn.disabled = false;
      btn.textContent = "Send";
    }
  };
</script>

