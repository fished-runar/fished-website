---
layout: layouts/base.njk
title: Fished – Media
description: News, press coverage and media resources from Fished — cloud-based software for the seafood industry.
canonical: /media
navSolid: true
activePage: media
permalink: /media.html
---
<section class="subhero">
  <div class="subhero-inner">
    <span class="subhero-tag">Media</span>
    <h1>News &amp;<br /><span>Media Resources</span></h1>
    <p>
      Press coverage, announcements and media resources from Fished &mdash; cloud-based software
      for the seafood industry.
    </p>
  </div>
</section>
<section class="section section-sm">
  <div class="container">
    <div style="text-align: center" class="reveal">
      <p class="section-label">Events</p>
      <h2 class="section-title dark">Where to Find Us</h2>
      <p class="section-body" style="max-width: 520px; margin-inline: auto">
        Conferences, trade shows and industry events we&rsquo;re attending or hosting.
      </p>
    </div>
    {% set sortedEvents = events | sort(false, false, "date") %}
    {% if sortedEvents.length < 2 %}
      {% set placeholderCount = 3 - sortedEvents.length %}
    {% else %}
      {% set placeholderCount = 1 %}
    {% endif %}
    {% set totalEventCards = sortedEvents.length + placeholderCount %}
    <div class="event-carousel reveal">
      {% if totalEventCards > 3 %}
      <button type="button" class="event-carousel-btn event-carousel-prev" aria-label="Previous events">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
      </button>
      {% endif %}
      <div class="event-carousel-viewport">
        <div class="event-grid" id="event-carousel-track">
          {% for item in sortedEvents %}
          <a class="event-card" data-event-date="{{ item.date }}" href="{{ item.link or '#' }}"{% if item.link %} target="_blank" rel="noopener"{% endif %}>
            <div class="ticket">
              <div class="t-main">
                <div class="t-content">
                  <div class="t-header">
                    <div class="t-logo">
                      <img src="/assets/fished/logo_White.png" alt="Fished" />
                    </div>
                    <div class="t-type">Event</div>
                  </div>
                  <div class="t-title">{{ item.title }}</div>
                  <div class="t-details">
                    <div class="t-detail-item">
                      <span class="t-label">Date</span>
                      <span class="t-value">{{ item.displayDate }}</span>
                    </div>
                    <div class="t-detail-item">
                      <span class="t-label">Venue</span>
                      <span class="t-value">{{ item.location }}</span>
                    </div>
                    {% if item.stand %}
                    <div class="t-detail-item">
                      <span class="t-label">Stand</span>
                      <span class="t-value">{{ item.stand }}</span>
                    </div>
                    {% endif %}
                  </div>
                </div>
              </div>
              <div class="t-perforation"><div class="t-perf-line"></div></div>
              <div class="t-stub">
                <div class="t-barcode-full"></div>
              </div>
            </div>
          </a>
          {% endfor %}
          {% for i in range(0, placeholderCount) %}
          <div class="event-card event-card--placeholder">
            <div class="ticket">
              <div class="t-main">
                <div class="t-content">
                  <div class="t-header">
                    <div class="t-logo">
                      <img src="/assets/fished/logo_White.png" alt="Fished" />
                    </div>
                    <div class="t-type">Event</div>
                  </div>
                  <div class="t-title">More Events Coming</div>
                </div>
              </div>
              <div class="t-perforation"><div class="t-perf-line"></div></div>
              <div class="t-stub">
                <div class="t-barcode-full"></div>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% if totalEventCards > 3 %}
      <button type="button" class="event-carousel-btn event-carousel-next" aria-label="Next events">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
      </button>
      {% endif %}
    </div>
  </div>
</section>
<section class="section section-sm customer-logos-section">
  <div class="container">
    <div style="text-align: center" class="reveal">
      <p class="section-label">Follow us</p>
      <h2 class="section-title dark">LinkedIn Feed</h2>
      <p class="section-body" style="max-width: 520px; margin-inline: auto">
        The latest updates and posts from Fished on LinkedIn.
      </p>
    </div>
    <div class="reveal" style="margin-top: 40px">
      <!-- Elfsight LinkedIn Feed | Fished LinkedIn Feed -->
      <script src="https://elfsightcdn.com/platform.js" async></script>
      <div class="elfsight-app-3f72c5f9-8a72-4e53-9bac-0b2cdd0a0d17" data-elfsight-app-lazy></div>
    </div>
  </div>
</section>
<section class="section section-sm">
  <div class="container">
    <div style="text-align: center" class="reveal">
      <p class="section-label">News</p>
      <h2 class="section-title dark">Latest News</h2>
      <p class="section-body" style="max-width: 520px; margin-inline: auto">
        Announcements and press coverage from Fished.
      </p>
    </div>
    <div class="news-carousel reveal">
      <button type="button" class="news-carousel-btn news-carousel-prev" aria-label="Previous articles">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
      </button>
      <div class="news-carousel-viewport">
        <div class="news-grid news-carousel-track" id="news-carousel-track">
          {% for item in news %}
          <a class="news-card" href="{{ item.link }}" target="_blank" rel="noopener">
            {% if item.image %}<img class="news-card-image" src="{{ item.image }}" alt="" />{% endif %}
            <div class="news-card-body">
              <span class="news-card-meta">{{ item.source }} &middot; {{ item.displayDate }}</span>
              <h3 class="news-card-title">{{ item.title }}</h3>
              <p class="news-card-desc">{{ item.description }}</p>
            </div>
          </a>
          {% endfor %}
        </div>
      </div>
      <button type="button" class="news-carousel-btn news-carousel-next" aria-label="Next articles">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
      </button>
    </div>
  </div>
</section>
{% include "components/cta-strip.njk" %}
<script>
  function initCarousel(trackId, prevSelector, nextSelector, getInitialIndex) {
    const track = document.getElementById(trackId);
    if (!track) return;
    const prevBtn = document.querySelector(prevSelector);
    const nextBtn = document.querySelector(nextSelector);
    if (!prevBtn || !nextBtn) return;
    const cards = Array.from(track.children);
    function step() {
      const gap = parseFloat(getComputedStyle(track).gap) || 0;
      return cards[0].getBoundingClientRect().width + gap;
    }
    function maxIndex() {
      const visible = Math.max(1, Math.round(track.parentElement.clientWidth / step()));
      return Math.max(0, cards.length - visible);
    }
    function contentWidth() {
      const gap = parseFloat(getComputedStyle(track).gap) || 0;
      return cards.reduce((sum, c) => sum + c.getBoundingClientRect().width, 0) + gap * (cards.length - 1);
    }
    let index = typeof getInitialIndex === "function" ? getInitialIndex(cards) : 0;
    index = Math.max(0, Math.min(index, maxIndex()));
    function render() {
      const viewportWidth = track.parentElement.clientWidth;
      const content = contentWidth();
      if (content <= viewportWidth) {
        track.style.transform = `translateX(${(viewportWidth - content) / 2}px)`;
      } else {
        track.style.transform = `translateX(${-index * step()}px)`;
      }
    }
    function go(delta) {
      const max = maxIndex();
      index += delta;
      if (index > max) index = 0;
      if (index < 0) index = max;
      render();
    }
    render();
    let timer = setInterval(() => go(1), 5000);
    function restart() {
      clearInterval(timer);
      timer = setInterval(() => go(1), 5000);
    }
    prevBtn.addEventListener("click", () => {
      go(-1);
      restart();
    });
    nextBtn.addEventListener("click", () => {
      go(1);
      restart();
    });
    window.addEventListener("resize", () => {
      index = Math.min(index, maxIndex());
      render();
    });
  }

  (function () {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    document.querySelectorAll(".event-card[data-event-date]").forEach((card) => {
      const eventDate = new Date(card.dataset.eventDate);
      if (!isNaN(eventDate) && eventDate < today) {
        card.classList.add("event-card--past");
      }
    });
  })();

  function eventInitialIndex(cards) {
    // Placeholder cards (no data-event-date) are always treated as "upcoming".
    let pivot = cards.findIndex((card) => !card.dataset.eventDate || !card.classList.contains("event-card--past"));
    if (pivot === -1) pivot = cards.length - 1;
    return pivot > 0 ? pivot - 1 : 0;
  }

  initCarousel("news-carousel-track", ".news-carousel-prev", ".news-carousel-next");
  initCarousel("event-carousel-track", ".event-carousel-prev", ".event-carousel-next", eventInitialIndex);
</script>
