      </button>
      <div class="news-carousel-viewport">
        <div class="news-grid news-carousel-track" id="linkedin-carousel-track"></div>
      </div>
      <button type="button" class="news-carousel-btn linkedin-carousel-next" aria-label="Next posts">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
      </button>
    </div>
  </div>
</section>
<section class="section section-sm">
  <div class="container">
    <div style="text-align: center" class="reveal">
      <p class="section-label">News</p>
      <h2 class="section-title dark">Latest News</h2>
      <p class="section-body" style="max-width: 520px; margin-inline: auto">
        Announcements and press coverage from Fished.
      </p>
    </div>
    <div class="news-carousel reveal">
      <button type="button" class="news-carousel-btn news-carousel-prev" aria-label="Previous articles">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
      </button>
      <div class="news-carousel-viewport">
        <div class="news-grid news-carousel-track" id="news-carousel-track">
          {% for item in news %}
          <a class="news-card" href="{{ item.link }}" target="_blank" rel="noopener">
            {% if item.image %}<img class="news-card-image" src="{{ item.image }}" alt="" />{% endif %}
            <div class="news-card-body">
              <span class="news-card-meta">{{ item.source }} &middot; {{ item.displayDate }}</span>
              <h3 class="news-card-title">{{ item.title }}</h3>
              <p class="news-card-desc">{{ item.description }}</p>
            </div>
          </a>
          {% endfor %}
        </div>
      </div>
      <button type="button" class="news-carousel-btn news-carousel-next" aria-label="Next articles">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
      </button>
    </div>
  </div>
</section>
{% include "components/cta-strip.njk" %}
<script>
  (function () {
    function initCarousel(trackId, prevSelector, nextSelector) {
      const track = document.getElementById(trackId);
      if (!track) return;
      const cards = Array.from(track.children);
      if (!cards.length) return;
      const prevBtn = document.querySelector(prevSelector);
      const nextBtn = document.querySelector(nextSelector);
      let index = 0;
      function step() {
        const gap = parseFloat(getComputedStyle(track).gap) || 0;
        return cards[0].getBoundingClientRect().width + gap;
      }
      function maxIndex() {
        const visible = Math.max(1, Math.round(track.parentElement.clientWidth / step()));
        return Math.max(0, cards.length - visible);
      }
      function render() {
        track.style.transform = `translateX(${-index * step()}px)`;
      }
      function go(delta) {
        const max = maxIndex();
        index += delta;
        if (index > max) index = 0;
        if (index < 0) index = max;
        render();
      }
      let timer = setInterval(() => go(1), 5000);
      function restart() {
        clearInterval(timer);
        timer = setInterval(() => go(1), 5000);
      }
      prevBtn.addEventListener("click", () => {
        go(-1);
        restart();
      });
      nextBtn.addEventListener("click", () => {
        go(1);
        restart();
      });
      window.addEventListener("resize", () => {
        index = Math.min(index, maxIndex());
        render();
      });
    }

    function escapeHtml(s) {
      return (s || "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]));
    }

    function fmtDate(iso) {
      const d = new Date(iso);
      if (isNaN(d)) return "";
      return d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
    }

    function pickImage(post) {
      const m = post.media && post.media[0];
      if (!m) return "";
      if (m.type === "image") return (m.standard && m.standard.url) || (m.thumbnail && m.thumbnail.url) || (m.original && m.original.url) || "";
      if (m.type === "video") return (m.cover && m.cover.original && m.cover.original.url) || "";
      if (m.type === "article") return (m.image && ((m.image.standard && m.image.standard.url) || (m.image.original && m.image.original.url))) || "";
      if (m.type === "document") return (m.images && m.images[0] && ((m.images[0].standard && m.images[0].standard.url) || (m.images[0].thumbnail && m.images[0].thumbnail.url))) || "";
      return "";
    }

    function proxyImage(url) {
      return url ? "/api/linkedin-image?url=" + encodeURIComponent(url) : "";
    }

    function renderLinkedInCard(post) {
      const img = proxyImage(pickImage(post));
      const caption = escapeHtml(post.caption || "");
      const date = fmtDate(post.publishedAt);
      return (
        `<a class="news-card" href="${post.link}" target="_blank" rel="noopener">` +
        (img ? `<img class="news-card-image" src="${img}" alt="" loading="lazy" />` : "") +
        `<div class="news-card-body">` +
        `<span class="news-card-meta">Fished on LinkedIn &middot; ${date}</span>` +
        `<p class="news-card-desc news-card-desc--clamp">${caption}</p>` +
        `</div></a>`
      );
    }

    async function loadLinkedInFeed() {
      const track = document.getElementById("linkedin-carousel-track");
      if (!track) return;
      try {
        const res = await fetch("/api/linkedin-feed");
        if (!res.ok) throw new Error("bad response");
        const data = await res.json();
        const posts = (data && data.payload) || [];
        if (!posts.length) throw new Error("no posts");
        track.innerHTML = posts.map(renderLinkedInCard).join("");
        initCarousel("linkedin-carousel-track", ".linkedin-carousel-prev", ".linkedin-carousel-next");
      } catch (err) {
        const carousel = document.getElementById("linkedin-carousel");
        if (carousel) carousel.style.display = "none";
      }
    }

    initCarousel("news-carousel-track", ".news-carousel-prev", ".news-carousel-next");
    loadLinkedInFeed();
  })();
</script>
