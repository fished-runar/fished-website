<nav class="nav{% if navSolid %} nav-solid{% endif %}">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img class="nav-logo-icon" src="{{ site.logoIcon }}" alt="" />
      <img class="nav-logo-text" src="{{ site.logoText }}" alt="{{ site.name }}" />
    </a>
    <ul class="nav-links" id="nav-links">
      {% for item in nav %}
      <li><a href="{{ item.href }}"{% if activePage == item.key %} class="active"{% endif %}>{{ item.label }}</a></li>
      {% endfor %}
      <li class="nav-links-cta"><a href="/#contact" class="btn btn-primary">Contact us</a></li>
    </ul>
    <a href="/#contact" class="btn btn-primary nav-cta-desktop">Contact us</a>
    <button type="button" class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>

</nav>
