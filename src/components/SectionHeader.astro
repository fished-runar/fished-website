---
interface Props {
  label?: string;
  title: string;
  body?: string;
  align?: 'center' | 'left';
  theme?: 'dark' | 'light';
}

const {
  label,
  title,
  body,
  align = 'center',
  theme = 'dark',
} = Astro.props;
---

<div style={align === 'center' ? 'text-align:center;' : ''} class="reveal">
  {label && <p class="section-label">{label}</p>}
  <h2 class={`section-title ${theme}`} set:html={title} />
  {body && <p class="section-body" style={align === 'center' ? 'max-width:520px; margin-inline:auto;' : ''}>{body}</p>}
</div>
