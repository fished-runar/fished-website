---
interface Props {
  heading?: string;
  body?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading = 'Ready to Transform<br />Your Operation?',
  body = 'Book a no-obligation chat with one of our sales representatives.',
  buttonText = 'Contact us',
  buttonHref = '/#contact',
} = Astro.props;
---

<section class="cta-strip">
  <div class="container">
    <h2 class="reveal" set:html={heading} />
    <p class="reveal">{body}</p>
    <a href={buttonHref} class="btn btn-outline-light reveal">{buttonText}</a>
  </div>
</section>
