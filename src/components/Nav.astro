---
interface Props {
  activePage?: 'features' | 'customers' | 'integrations' | 'about';
  transparent?: boolean;
}

const { activePage, transparent = false } = Astro.props;
---

<nav class={`nav${transparent ? '' : ' nav-solid'}`}>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img class="nav-logo-icon" src="/assets/fished/Fished - Logo.svg" alt="" />
      <img class="nav-logo-text" src="/assets/fished/Fished - Without logo - blue.svg" alt="Fished" />
    </a>
    <ul class="nav-links">
      <li><a href="/features" class={activePage === 'features' ? 'active' : ''}>Features</a></li>
      <li><a href="/customers" class={activePage === 'customers' ? 'active' : ''}>Customers</a></li>
      <li><a href="/integrations" class={activePage === 'integrations' ? 'active' : ''}>Integrations</a></li>
      <li><a href="/about" class={activePage === 'about' ? 'active' : ''}>About us</a></li>
    </ul>
    <a href="/#contact" class="btn btn-primary">Contact us</a>
  </div>
</nav>
