---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaStrip from '../components/CtaStrip.astro';

const teamGlob = import.meta.glob('../../content/team/*.json', { eager: true });
const team = (Object.values(teamGlob) as any[]).sort((a, b) => (a.order ?? 99) - (b.order ?? 99));

const officesGlob = import.meta.glob('../../content/offices/*.json', { eager: true });
const offices = (Object.values(officesGlob) as any[]).sort((a, b) => (a.order ?? 99) - (b.order ?? 99));
const officesData = offices.map((o: any) => ({ lat: o.lat, lng: o.lng, title: o.city, url: o.mapsUrl }));
---

<BaseLayout
  title="Fished &#8211; About Us"
  description="Built from the ground up for the seafood industry. Meet the team and find our offices across Norway."
  canonical="https://fished.com/about"
  activePage="about"
>

  <section class="subhero">
    <div class="subhero-inner">
      <span class="subhero-tag">Who We Are</span>
      <h1>Our Story</h1>
      <p>Built from the ground up, without technical legacy &mdash; purely for the seafood industry.</p>
    </div>
  </section>

  <!-- Story -->
  <section class="section story-section">
    <div class="container">
      <div class="split reveal">
        <div>
          <p class="section-label">Our approach</p>
          <h2 class="section-title dark">By the Industry,<br />For the Industry</h2>
          <p class="section-body">
            Without technical heritage, Fished is developed from the ground up to meet the specific needs of the
            seafood industry. With the vision &ldquo;by the industry &mdash; for the industry&rdquo;, we work closely with our
            customers to continuously adapt the system to new challenges and opportunities.
          </p>
          <p class="section-body" style="margin-top:16px;">
            Our roadmap is shaped in partnership with selected seafood companies, ensuring that every feature we
            build solves real problems for real people in the industry.
          </p>
          <div style="margin-top: 32px;">
            <a href="/#contact" class="btn btn-primary">Contact us</a>
          </div>
        </div>
        <div class="split-image">
          <img src="/assets/photos/team.png" alt="The Fished team" />
        </div>
      </div>
    </div>
  </section>

  <!-- Offices map -->
  <section class="offices-section">
    <div id="offices-map-canvas"></div>
    <div class="offices-overlay">
      <p class="section-label light">Our offices</p>
      <h2 class="section-title" style="color:#fff;">Where We Are</h2>
      <p class="section-body" style="color:rgba(255,255,255,0.75); margin-top:8px; max-width:320px;">
        Fished operates across Norway, strategically located in key seafood regions.
      </p>
      <div class="offices-list">
        {offices.map((o: any) => (
          <a class="office-item" href={o.mapsUrl} target="_blank" rel="noopener">
            <div class="office-pin">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <strong>{o.city}</strong>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section" style="background: var(--white);">
    <div class="container">
      <div style="text-align:center;" class="reveal">
        <p class="section-label">The Team</p>
        <h2 class="section-title dark">Meet the People<br />Behind Fished</h2>
      </div>
      <div class="team-grid">
        {team.map((m: any) => (
          <div class="team-card reveal">
            <img class="team-card-photo" src={m.photo} alt={m.name} loading="lazy" />
            <div class="team-card-body">
              <p class="team-card-name">{m.name}</p>
              <p class="team-card-role">{m.role}</p>
              <div class="team-card-contacts">
                {m.phone && (
                  <a href={m.phone}><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>{m.phone.replace('tel:','').replace(/^\+47(\d{2})(\d{3})(\d{2})(\d{2})$/, '+47 $1 $2 $3 $4')}</a>
                )}
                {m.email && (
                  <a href={`mailto:${m.email}`}><svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>{m.email}</a>
                )}
              </div>
              {m.linkedin && (
                <div class="team-card-linkedin"><a href={m.linkedin} target="_blank" rel="noopener"><svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>LinkedIn</a></div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaStrip />

</BaseLayout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<script define:vars={{ officesData }}>
  (function() {
    var MAP_STYLE = [
      { elementType: 'geometry', stylers: [{ color: '#1a2340' }] },
      { elementType: 'labels.text.fill', stylers: [{ color: '#8fa0c0' }] },
      { elementType: 'labels.text.stroke', stylers: [{ color: '#1a2340' }] },
      { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#0d1726' }] },
      { featureType: 'water', elementType: 'labels.text.fill', stylers: [{ color: '#3d6b9f' }] },
      { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#2a3a5c' }] },
      { featureType: 'road', elementType: 'geometry.stroke', stylers: [{ color: '#1a2340' }] },
      { featureType: 'road.highway', elementType: 'geometry', stylers: [{ color: '#3a4bbf' }] },
      { featureType: 'administrative', elementType: 'geometry.stroke', stylers: [{ color: '#3a4bbf' }, { weight: 1 }] },
      { featureType: 'administrative.country', elementType: 'labels.text.fill', stylers: [{ color: '#aab8d8' }] },
      { featureType: 'administrative.locality', elementType: 'labels.text.fill', stylers: [{ color: '#c5d0e8' }] },
      { featureType: 'poi', stylers: [{ visibility: 'off' }] },
      { featureType: 'transit', stylers: [{ visibility: 'off' }] },
      { featureType: 'landscape', elementType: 'geometry', stylers: [{ color: '#1e2e4a' }] }
    ];
    var OFFICES = officesData;
    window.initOfficesMap = function() {
      var map = new google.maps.Map(document.getElementById('offices-map-canvas'), {
        center: { lat: 65.0, lng: 10.5 },
        zoom: 5,
        styles: MAP_STYLE,
        disableDefaultUI: true,
        gestureHandling: 'cooperative'
      });
      var canvas = document.getElementById('offices-map-canvas');
      canvas.addEventListener('wheel', function(e) {
        if (!e.ctrlKey) { e.stopPropagation(); }
      }, { capture: true, passive: true });
      OFFICES.forEach(function(office) {
        var marker = new google.maps.Marker({
          position: { lat: office.lat, lng: office.lng },
          map: map,
          title: office.title,
          icon: {
            path: google.maps.SymbolPath.CIRCLE,
            scale: 9,
            fillColor: '#5060db',
            fillOpacity: 1,
            strokeColor: '#ffffff',
            strokeWeight: 2
          }
        });
        marker.addListener('click', function() {
          window.open(office.url, '_blank', 'noopener');
        });
      });
    };
  })();
</script>
<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBaiKtqveJbTdJCZKE9IzvD-K9S67Ic_fA&callback=initOfficesMap" async defer></script>
