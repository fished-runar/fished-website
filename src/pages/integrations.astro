---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaStrip from '../components/CtaStrip.astro';
---

<BaseLayout
  title="Fished &#8211; Integrations"
  description="Fished integrates with the tools and platforms your business already relies on &#8212; seamlessly and out of the box."
  canonical="https://fished.com/integrations"
  activePage="integrations"
>

  <section class="subhero">
    <div class="subhero-inner">
      <span class="subhero-tag">Integrations</span>
      <h1>Connecting Your<br /><span>Entire Ecosystem</span></h1>
      <p>Fished integrates with the tools and platforms your business already relies on &mdash; seamlessly and out of the box.</p>
    </div>
  </section>

  <section class="section section-sm customer-logos-section">
    <div class="container">
      <div style="text-align:center;" class="reveal">
        <p class="section-label">Partners &amp; Integrations</p>
        <h2 class="section-title dark">Our Integration Partners</h2>
        <p class="section-body" style="max-width:520px; margin-inline:auto;">
          From accounting and banking to logistics and government systems &mdash; Fished connects to your whole stack.
        </p>
      </div>
    </div>
    <div class="container">
      <div class="customer-logos-grid reveal">
        <img src="/assets/integrations/svg/business-central.svg" alt="Microsoft Business Central" loading="lazy" />
        <img src="/assets/integrations/svg/visma-business.svg" alt="Visma Business" loading="lazy" />
        <img src="/assets/integrations/svg/tripletex.svg" alt="Tripletex" loading="lazy" />
        <img src="/assets/integrations/svg/xledger.svg" alt="Xledger" loading="lazy" />
        <img src="/assets/integrations/svg/uniconta.svg" alt="Uniconta" loading="lazy" />
        <img src="/assets/integrations/svg/business-nxt.svg" alt="Business NXT" loading="lazy" />
        <img src="/assets/integrations/svg/finago.svg" alt="Finago" loading="lazy" />
        <img src="/assets/integrations/png/poweroffice-go.png" alt="PowerOffice GO" loading="lazy" />
        <img src="/assets/integrations/svg/nordea.svg" alt="Nordea" loading="lazy" />
        <img src="/assets/integrations/svg/sparebank1.svg" alt="SpareBank 1" loading="lazy" />
        <img src="/assets/integrations/svg/svea.svg" alt="Svea" loading="lazy" />
        <img src="/assets/integrations/svg/atradius.svg" alt="Atradius" loading="lazy" />
        <img src="/assets/integrations/svg/allianz.svg" alt="Allianz" loading="lazy" />
        <img src="/assets/integrations/png/norges-rafisklag.png" alt="Norges Rafisklag" loading="lazy" />
        <img src="/assets/integrations/svg/fiskeridirektoratet.svg" alt="Fiskeridirektoratet" loading="lazy" />
        <img src="/assets/integrations/svg/tolletaten.svg" alt="Tolletaten" loading="lazy" />
        <img src="/assets/integrations/svg/marel.svg" alt="Marel" loading="lazy" />
        <img src="/assets/integrations/svg/emma-systems.svg" alt="Emma Systems" loading="lazy" />
        <img src="/assets/integrations/svg/multipack.svg" alt="Multipack" loading="lazy" />
        <img src="/assets/integrations/svg/surofi.svg" alt="Surofi" loading="lazy" />
        <img src="/assets/integrations/svg/edi.svg" alt="EDI" loading="lazy" />
        <img src="/assets/integrations/svg/zugferd.svg" alt="ZUGFeRD" loading="lazy" />
        <img src="/assets/integrations/png/power-bi.png" alt="Power BI" loading="lazy" />
        <img src="/assets/integrations/svg/catch-certificate.svg" alt="Catch Certificate" loading="lazy" />
        <img src="/assets/integrations/png/oslo-seafood-center.png" alt="Oslo Seafood Center" loading="lazy" />
        <img src="/assets/integrations/png/tradeblock.png" alt="Tradeblock" loading="lazy" />
      </div>
    </div>
  </section>

  <CtaStrip />

</BaseLayout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
