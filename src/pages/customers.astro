---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaStrip from '../components/CtaStrip.astro';
---

<BaseLayout
  title="Fished &#8211; Customer Stories"
  description="Seafood companies across Norway trust Fished to run their daily operations. Read their stories."
  canonical="https://fished.com/customers"
  activePage="customers"
>

  <section class="subhero">
    <div class="subhero-inner">
      <span class="subhero-tag">Customer Stories</span>
      <h1>Success Stories from<br /><span>Our Customers</span></h1>
      <p>Seafood companies across Norway trust Fished to run their daily operations. Here is what they say.</p>
    </div>
  </section>

  <!-- Logo grid -->
  <section class="section customer-logos-section">
    <div class="container">
      <div style="text-align:center;" class="reveal">
        <p class="section-label">Our customers</p>
        <h2 class="section-title">Companies That Trust Fished</h2>
      </div>
      <div class="customer-logos-grid reveal">
        <img src="/assets/customers/png/hofseth.png" alt="Hofseth" loading="lazy" />
        <img src="/assets/customers/png/siguna.png" alt="Siguna" loading="lazy" />
        <img src="/assets/customers/png/nordic-wildfish.png" alt="Nordic Wildfish" loading="lazy" />
        <img src="/assets/customers/png/c-food-norway.png" alt="C-Food Norway" loading="lazy" />
        <img src="/assets/customers/png/silver-seafood.png" alt="Silver Seafood" loading="lazy" />
        <img src="/assets/customers/png/longvagruppen.png" alt="Longvagruppen" loading="lazy" />
        <img src="/assets/customers/png/MORECOD.png" alt="MORECOD" loading="lazy" />
        <img src="/assets/customers/png/ingolf-engeset.png" alt="Ingolf Engeset" loading="lazy" />
        <img src="/assets/customers/svg/jangaard.svg" alt="Jangaard" loading="lazy" />
        <img src="/assets/customers/png/aalesundfish.png" alt="&#197;lesund Fisk" loading="lazy" />
        <img src="/assets/customers/png/nordic-group.png" alt="Nordic Group" loading="lazy" />
        <img src="/assets/customers/png/westcoast.png" alt="Westcoast" loading="lazy" />
        <img src="/assets/customers/png/bluewild.png" alt="Bluewild" loading="lazy" />
        <img src="/assets/customers/png/myre-fiskemottak.png" alt="Myre Fiskemottak" loading="lazy" />
        <img src="/assets/customers/png/fjellfisk-sort.png" alt="Fjellfisk" loading="lazy" />
        <img src="/assets/customers/png/golden-atlantic.png" alt="Golden Atlantic" loading="lazy" />
        <img src="/assets/customers/png/brødrene-remø.png" alt="Brødrene Remø" loading="lazy" />
        <img src="/assets/customers/png/west-norway.png" alt="West Norway" loading="lazy" />
        <img src="/assets/customers/png/icefresh.png" alt="Icefresh" loading="lazy" />
        <img src="/assets/customers/svg/kaldvik.svg" alt="Kaldvik" loading="lazy" />
        <img src="/assets/customers/png/jm-langaas.png" alt="JM Langaas" loading="lazy" />
        <img src="/assets/customers/png/vesteraalens.png" alt="Vesteraalens" loading="lazy" />
        <img src="/assets/customers/png/Filetfabrikken.png" alt="Filetfabrikken" loading="lazy" />
        <img src="/assets/customers/svg/egersund-group.svg" alt="Egersund Group" loading="lazy" />
        <img src="/assets/customers/svg/johan-giskeodegard.svg" alt="Johan Giskeodegård" loading="lazy" />
        <img src="/assets/customers/png/atlas-premium.png" alt="Atlas Premium" loading="lazy" />
        <img src="/assets/customers/png/bergen-seafood.png" alt="Bergen Seafood" loading="lazy" />
        <img src="/assets/customers/png/finnvik-eiendom.png" alt="Finnvik" loading="lazy" />
        <img src="/assets/customers/png/frigocare.png" alt="Frigocare" loading="lazy" />
        <img src="/assets/customers/png/havoysund-fisk.png" alt="Håvøysund Fisk" loading="lazy" />
        <img src="/assets/customers/png/skaar.png" alt="Skår" loading="lazy" />
        <img src="/assets/customers/png/NilsSperre_log-removebg-preview.png" alt="Nils Sperre" loading="lazy" />
        <img src="/assets/customers/png/NorjaSeafood_logo-removebg-preview.png" alt="Norja Seafood" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testimonials-section">
    <div class="container">
      <div style="text-align:center;" class="reveal">
        <p class="section-label">What customers say</p>
        <h2 class="section-title">Trusted by the Industry</h2>
      </div>
      <div class="testimonials-track three-col">

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/png/hofseth.png" data-logo-alt="Hofseth"
          data-photo="/assets/photos/testimonial-hofseth.webp" data-photo-alt="Hofseth team"
          data-quote="&ldquo;We couldn&rsquo;t be more pleased! Short story, the solution is developed by the users, for the users. That&rsquo;s why we are so pleased. Because the system meets the needs of the individual customer!&rdquo;"
          data-authors="Roger Hofseth|CCO, Hofseth">
          <img class="testimonial-logo" src="/assets/customers/png/hofseth.png" alt="Hofseth" />
          <p class="testimonial-quote">&ldquo;We couldn&rsquo;t be more pleased! Short story, the solution is developed by the users, for the users. That&rsquo;s why we are so pleased. Because the system meets the needs of the individual customer!&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Roger Hofseth</strong><span>CCO, Hofseth</span></div></div>
        </div>

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/png/siguna.png" data-logo-alt="Siguna"
          data-photo="/assets/photos/testimonial-siguna.jpg" data-photo-alt="Siguna team"
          data-quote="&ldquo;We have chosen Fished as our order management provider because they offer a modern and flexible solution tailored to the needs of the seafood industry, while also giving us better oversight, traceability, and more efficient work processes.&rdquo;"
          data-authors="Evgenia Kozlova|CEO, Siguna">
          <img class="testimonial-logo" src="/assets/customers/png/siguna.png" alt="Siguna" />
          <p class="testimonial-quote">&ldquo;We have chosen Fished as our order management provider because they offer a modern and flexible solution tailored to the needs of the seafood industry, while also giving us better oversight, traceability, and more efficient work processes.&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Evgenia Kozlova</strong><span>CEO, Siguna</span></div></div>
        </div>

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/png/nordic-wildfish.png" data-logo-alt="Nordic Wildfish"
          data-photo="/assets/photos/testimonial-nordicwildfish.webp" data-photo-alt="Nordic Wildfish team"
          data-quote="&ldquo;Fished works great &mdash; it&rsquo;s both intuitive and functional. My favourite features are the universal search field, pallet tracking and the ability to easily correct my own mistakes &mdash; all of which make my daily work more efficient.&rdquo;"
          data-authors="Elisabeth Myklebust|Logistics &amp; Export Coordinator, Nordic Wildfish">
          <img class="testimonial-logo" src="/assets/customers/png/nordic-wildfish.png" alt="Nordic Wildfish" />
          <p class="testimonial-quote">&ldquo;Fished works great &mdash; it&rsquo;s both intuitive and functional. My favourite features are the universal search field, pallet tracking and the ability to easily correct my own mistakes &mdash; all of which make my daily work more efficient.&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Elisabeth Myklebust</strong><span>Logistics &amp; Export Coordinator, Nordic Wildfish</span></div></div>
        </div>

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/png/nordic-wildfish.png" data-logo-alt="Nordic Wildfish"
          data-quote="&ldquo;We are very satisfied with the entire planning and implementation of Fished. The team at Fished has very good insight and experience to understand and solve our needs.&rdquo;"
          data-authors="Jon Hallvard Roaldsnes|CEO, Nordic Wildfish">
          <img class="testimonial-logo" src="/assets/customers/png/nordic-wildfish.png" alt="Nordic Wildfish" />
          <p class="testimonial-quote">&ldquo;We are very satisfied with the entire planning and implementation of Fished. The team at Fished has very good insight and experience to understand and solve our needs.&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Jon Hallvard Roaldsnes</strong><span>CEO, Nordic Wildfish</span></div></div>
        </div>

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/png/bluewild.png" data-logo-alt="Bluewild"
          data-quote="&ldquo;Fished has many options and is very user-friendly, which makes our everyday life more efficient. All companies in need of good inventory management should consider Fished &mdash; we simply couldn&rsquo;t have done without it. After we started using Fished, we have gained better cost control and greater focus on internal routines, which has led to a more streamlined workday. In addition, Fished delivers the best customer service on the market &mdash; they are fast, helpful and solution-oriented, which gives us peace of mind in our everyday lives. After we started using Fished, our workday has become much easier.&rdquo;"
          data-authors="Beate Lid|Logistics Manager and Sales, Bluewild">
          <img class="testimonial-logo" src="/assets/customers/png/bluewild.png" alt="Bluewild" />
          <p class="testimonial-quote">&ldquo;Fished has many options and is very user-friendly, which makes our everyday life more efficient. All companies in need of good inventory management should consider Fished &mdash; we simply couldn&rsquo;t have done without it.&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Beate Lid</strong><span>Logistics Manager and Sales, Bluewild</span></div></div>
        </div>

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/svg/jangaard.svg" data-logo-alt="Jangaard"
          data-quote="&ldquo;We needed a new and modern system for our seafood trade, and Fished delivered. We have a brand new engine. It works very well and it&rsquo;s funny to think that we changed the system while production was going on as usual. There is always a risk when replacing the entire software system, but it has actually gone very well! I would say that all the information related to our seafood trade has been made more accessible to everyone in the company. In a simple and clear way, we can access the information we request. The flow of information internally has improved and the system is almost intuitively self-explanatory. The cloud-based solution has made seafood trading easier and more efficient.&rdquo;"
          data-authors="Knut Andreas Blankholm|CFO, Jangaard">
          <img class="testimonial-logo" src="/assets/customers/svg/jangaard.svg" alt="Jangaard" />
          <p class="testimonial-quote">&ldquo;We needed a new and modern system for our seafood trade, and Fished delivered. We have a brand new engine. It works very well &mdash; the information flow has improved and the system is almost intuitively self-explanatory.&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Knut Andreas Blankholm</strong><span>CFO, Jangaard</span></div></div>
        </div>

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/png/nordic-group.png" data-logo-alt="Nordic Group"
          data-quote="&ldquo;Fished is a highly user-friendly system with almost endless possibilities. What impresses us the most is how receptive the team is to feedback, and how quickly they work to further develop solutions. The search functions and overviews make it easy to find information quickly, which significantly streamlines everyday work. The transition to Fished has been a very positive experience, and it is a decision we are very happy with. We look forward to what&rsquo;s ahead.&rdquo;"
          data-authors="Marina Thomassen|Logistics Backoffice, Nordic Group;;Stefan Hansen|Økonomisjef og leder backoffice, Nordic Group;;Erling Johannes Strøm|Logistics, Nordic Group">
          <img class="testimonial-logo" src="/assets/customers/png/nordic-group.png" alt="Nordic Group" />
          <p class="testimonial-quote">&ldquo;Fished is a highly user-friendly system with almost endless possibilities. What impresses us the most is how receptive the team is to feedback, and how quickly they work to further develop solutions.&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Marina Thomassen</strong><span>Logistics Backoffice, Nordic Group</span></div></div>
        </div>

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/png/golden-atlantic.png" data-logo-alt="Golden Atlantic"
          data-quote="&ldquo;More and more features are coming that make my everyday life easier, and we like that. It looks like it&rsquo;s going to be an extremely hectic year, so the fact that we&rsquo;re already starting to find a good flow in Fished is crucial.&rdquo;"
          data-authors="Kristian Alfredsen Fossum|Operational Manager, Golden Atlantic">
          <img class="testimonial-logo" src="/assets/customers/png/golden-atlantic.png" alt="Golden Atlantic" />
          <p class="testimonial-quote">&ldquo;More and more features are coming that make my everyday life easier, and we like that. It looks like it&rsquo;s going to be an extremely hectic year, so the fact that we&rsquo;re already starting to find a good flow in Fished is crucial.&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Kristian Alfredsen Fossum</strong><span>Operational Manager, Golden Atlantic</span></div></div>
        </div>

        <div class="testimonial-card reveal"
          data-logo="/assets/customers/png/hofseth.png" data-logo-alt="Hofseth Europe"
          data-quote="&ldquo;We have gone from a system that did not function optimally to one that gives us significantly better control over the cold storage, everything from what is in stock, where it is located and when it was produced. In addition to good features and improvements in our operations, we feel that we are in very safe and competent hands &mdash; an important, but not so easily measurable factor!&rdquo;"
          data-authors="Bjarki C. a Lag|Sales Manager, Hofseth Europe">
          <img class="testimonial-logo" src="/assets/customers/png/hofseth.png" alt="Hofseth Europe" />
          <p class="testimonial-quote">&ldquo;We have gone from a system that did not function optimally to one that gives us significantly better control over the cold storage, everything from what is in stock, where it is located and when it was produced.&rdquo;</p>
          <button class="btn-read-more">Read more &rarr;</button>
          <div class="testimonial-author"><div><strong>Bjarki C. a Lag</strong><span>Sales Manager, Hofseth Europe</span></div></div>
        </div>

      </div>
    </div>
  </section>

  <!-- Modal -->
  <div class="t-modal-overlay" id="t-modal-overlay" role="dialog" aria-modal="true">
    <div class="t-modal" id="t-modal">
      <button class="t-modal-close" id="t-modal-close" aria-label="Close">&times;</button>
      <img class="t-modal-logo" id="t-modal-logo" src="" alt="" />
      <img class="t-modal-photo" id="t-modal-photo" src="" alt="" style="display:none" />
      <p class="t-modal-quote" id="t-modal-quote"></p>
      <div class="t-modal-authors" id="t-modal-authors"></div>
    </div>
  </div>

  <CtaStrip />

</BaseLayout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  const overlay = document.getElementById('t-modal-overlay');
  const modalLogo = document.getElementById('t-modal-logo');
  const modalPhoto = document.getElementById('t-modal-photo');
  const modalQuote = document.getElementById('t-modal-quote');
  const modalAuthors = document.getElementById('t-modal-authors');

  function openModal(card) {
    modalLogo.src = card.dataset.logo || '';
    modalLogo.alt = card.dataset.logoAlt || '';
    const photo = card.dataset.photo;
    if (photo) { modalPhoto.src = photo; modalPhoto.alt = card.dataset.photoAlt || ''; modalPhoto.style.display = ''; }
    else { modalPhoto.style.display = 'none'; }
    modalQuote.innerHTML = card.dataset.quote || '';
    const authors = (card.dataset.authors || '').split(';;');
    modalAuthors.innerHTML = authors.map(a => {
      const [name, role] = a.split('|');
      return `<div class="t-modal-author"><strong>${name}</strong><span>${role || ''}</span></div>`;
    }).join('');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.btn-read-more').forEach(btn => {
    btn.addEventListener('click', () => openModal(btn.closest('.testimonial-card')));
  });
  document.getElementById('t-modal-close').addEventListener('click', closeModal);
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
