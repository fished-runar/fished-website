---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaStrip from '../components/CtaStrip.astro';
import CustomerLogosSection from '../components/tina/CustomerLogosSection';
import TestimonialsSection from '../components/tina/TestimonialsSection';
import { client } from '../../tina/__generated__/client';

const customersResponse = await client.queries.customerConnection();
const testimonialsResponse = await client.queries.testimonialConnection();
---

<BaseLayout
  title="Fished &#8211; Customer Stories"
  description="Seafood companies across Norway trust Fished to run their daily operations. Read their stories."
  canonical="https://fished.com/customers"
  activePage="customers"
>

  <section class="subhero">
    <div class="subhero-inner">
      <span class="subhero-tag">Customer Stories</span>
      <h1>Success Stories from<br /><span>Our Customers</span></h1>
      <p>Seafood companies across Norway trust Fished to run their daily operations. Here is what they say.</p>
    </div>
  </section>

  <!-- Logo grid -->
  <section class="section customer-logos-section">
    <div class="container">
      <div style="text-align:center;" class="reveal">
        <p class="section-label">Our customers</p>
        <h2 class="section-title">Companies That Trust Fished</h2>
      </div>
      <CustomerLogosSection
        data={customersResponse.data}
        query={customersResponse.query}
        variables={customersResponse.variables}
        client:only="react"
      />
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testimonials-section">
    <div class="container">
      <div style="text-align:center;" class="reveal">
        <p class="section-label">What customers say</p>
        <h2 class="section-title">Trusted by the Industry</h2>
      </div>
      <TestimonialsSection
        data={testimonialsResponse.data}
        query={testimonialsResponse.query}
        variables={testimonialsResponse.variables}
        client:only="react"
      />
    </div>
  </section>

  <CtaStrip />

</BaseLayout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
