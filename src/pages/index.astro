---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaStrip from '../components/CtaStrip.astro';
---

<BaseLayout
  title="Fished &#8212; Seafood Industry Software"
  description="Fished is cloud-based software built for the seafood industry. Manage purchase orders, warehouse operations, invoicing and integrations in one platform."
  canonical="https://fished.com"
  transparentNav={true}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-video">
      <iframe
        src="https://customer-99mkqqxjmk8osig7.cloudflarestream.com/5bf9f604ea3bf8eaef7a345235db4b15/iframe?muted=true&preload=true&loop=true&autoplay=true&poster=https%3A%2F%2Fcustomer-99mkqqxjmk8osig7.cloudflarestream.com%2F5bf9f604ea3bf8eaef7a345235db4b15%2Fthumbnails%2Fthumbnail.jpg%3Ftime%3D%26height%3D600&controls=false"
        allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture"
        allowfullscreen
        title="Fished hero video"
      ></iframe>
    </div>
    <div class="hero-container">
      <div class="hero-content">
        <h1>A Comprehensive Solution<br /><span>For the Seafood Industry</span></h1>
        <p>Fished brings purchase orders, inventory, warehouse management, invoicing and integrations together on one platform &#8212; simplifying your entire operation.</p>
        <div class="hero-cta">
          <a href="#contact" class="btn btn-primary">Contact us</a>
          <a href="/features" class="btn btn-outline-light">See Features</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div class="section-intro reveal">
        <p class="section-label">What we do</p>
        <h2 class="section-title dark">Built for the Seafood Industry,<br />From the Ground Up</h2>
        <p class="section-body">
          Fished is a cloud-based platform that connects purchase orders, warehouse management, invoicing and integrations in one place &#8212; built in close collaboration with the industry, for the industry.
        </p>
      </div>
    </div>
  </section>

  <!-- Customer-Driven -->
  <section class="section" style="background: var(--blue-light);">
    <div class="container">
      <div class="split reverse reveal">
        <div>
          <p class="section-label">Our approach</p>
          <h2 class="section-title">Customer-Driven Innovation</h2>
          <p class="section-body">
            Fished is developed in close collaboration with our users, regardless of whether they are large or
            small players in the seafood industry. Through our built-in feedback function, customers can easily
            influence future functionality. Our roadmap for further development is shaped in partnership with
            selected seafood companies, ensuring solutions that meet the real needs of the industry.
          </p>
        </div>
        <div class="split-image">
          <img src="/assets/graphics/customer-driven.png" alt="Customer-driven development" />
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose -->
  <section class="section">
    <div class="container">
      <div style="text-align:center;" class="reveal">
        <p class="section-label">Why us</p>
        <h2 class="section-title">Why Choose Fished?</h2>
      </div>
      <div class="why-grid">
        <div class="why-card reveal">
          <div class="why-card-icon">
            <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h4>Easy to Use with Just a Few Keystrokes</h4>
          <p>With an intuitive interface and a few keystrokes, you can efficiently handle purchasing, sales and inventory management.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-card-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h4>Low Implementation Costs</h4>
          <p>Fished grows with your business &#8212; with no hidden costs, and always available when you need it. No extra cost per user and full flexibility.</p>
        </div>
        <div class="why-card reveal">
          <div class="why-card-icon">
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h4>The Market's Best Customer Service</h4>
          <p>We put our customers first and offer the best customer service in the market &#8212; close follow-up from day one.</p>
        </div>
      </div>
    </div>
  </section>

