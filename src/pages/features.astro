---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaStrip from '../components/CtaStrip.astro';
---

<BaseLayout
  title="Fished &#8211; Platform Features"
  description="Explore Fished's full feature set: order management, warehouse, reporting, inbound invoice, tracing, automations and CRM &#8212; all in one platform."
  canonical="https://fished.com/features"
  activePage="features"
>

  <section class="subhero">
    <div class="subhero-inner">
      <span class="subhero-tag">Platform Capabilities</span>
      <h1>Everything You Need,<br /><span>In One Platform</span></h1>
      <p>From purchase orders to invoicing, warehouse management to integrations &mdash; Fished connects every part of your operation.</p>
    </div>
  </section>

  <section class="section" style="background: var(--blue-light);">
    <div class="container">
      <div class="features-layout">
        <div class="reveal">
          <p class="section-label">Platform capabilities</p>
          <h2 class="section-title">Feature Overview</h2>
          <p class="section-body">
            Built in close collaboration with the seafood industry, every module in Fished is designed around real workflows.
          </p>
          <ul class="feature-list">
            <li class="feature-list-item reveal">
              <span class="feature-num">01</span>
              <div>
                <h4>Order Management</h4>
                <p>Handle purchase and sales orders with certifications, catch certificates and export documentation in one flow.</p>
              </div>
            </li>
            <li class="feature-list-item reveal">
              <span class="feature-num">02</span>
              <div>
                <h4>Warehouse Module</h4>
                <p>Real-time inventory control for terminals and floor staff, directly connected to orders and invoicing.</p>
              </div>
            </li>
            <li class="feature-list-item reveal">
              <span class="feature-num">03</span>
              <div>
                <h4>Reporting &amp; Analytics</h4>
                <p>Live data on sales, margins, volume and costs. Drill down by customer, category or period. Export anywhere.</p>
              </div>
            </li>
            <li class="feature-list-item reveal">
              <span class="feature-num">04</span>
              <div>
                <h4>Inbound Invoice</h4>
                <p>Fished reads, interprets and matches invoices to your orders automatically. You approve &mdash; we handle the rest.</p>
              </div>
            </li>
            <li class="feature-list-item reveal">
              <span class="feature-num">05</span>
              <div>
                <h4>Tracing</h4>
                <p>Full traceability across all transactions. Search and find origin information in seconds.</p>
              </div>
            </li>
            <li class="feature-list-item reveal">
              <span class="feature-num">06</span>
              <div>
                <h4>Automations</h4>
                <p>Build rules without coding. Trigger approvals, notifications and system updates on any event.</p>
              </div>
            </li>
            <li class="feature-list-item reveal">
              <span class="feature-num">07</span>
              <div>
                <h4>CRM</h4>
                <p>Track customer relations, quotes and activity history &mdash; connected directly to your orders and invoices.</p>
              </div>
            </li>
          </ul>
        </div>
        <div class="features-img-card reveal">
          <img src="/assets/graphics/Fisher infographic Live type.jpg" alt="Fished platform overview &mdash; modules and integrations" />
        </div>
      </div>
    </div>
  </section>

  <CtaStrip />

</BaseLayout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
