{% include "components/cta-strip.njk" %}
<script>
  (function () {
    const tabs = document.querySelectorAll(".fv-tab"),
      panels = document.querySelectorAll(".fv-panel");
    function go(i) {
      tabs.forEach((t) => t.classList.remove("fv-on"));
      panels.forEach((p) => p.classList.remove("fv-on"));
      tabs[i].classList.add("fv-on");
      panels[i].classList.add("fv-on");
    }
    tabs.forEach((t, i) => t.addEventListener("click", () => go(i)));
  })();
</script>
