---
layout: layouts/base.njk
title: Fished – Customer Stories
description: Seafood companies across Norway trust Fished to run their daily operations. Read their stories.
canonical: /customers
navSolid: true
activePage: customers
permalink: /customers.html
---
{% from "components/logos-grid.njk" import logosGrid %}
{% from "components/testimonial-card.njk" import testimonialCard %}
<section class="subhero">
  <div class="subhero-inner">
    <span class="subhero-tag">Customer Stories</span>
    <h1>Success Stories from<br /><span>Our Customers</span></h1>
    <p>Seafood companies across Norway trust Fished to run their daily operations. Here is what they say.</p>
  </div>
</section>
<section class="section customer-logos-section">
  <div class="container">
    <div style="text-align: center" class="reveal">
      <p class="section-label">Our customers</p>
      <h2 class="section-title">Companies That Trust Fished</h2>
    </div>
    {{ logosGrid(customerLogos) }}
  </div>
</section>
<section class="section testimonials-section">
  <div class="container">
    <div style="text-align: center" class="reveal">
      <p class="section-label">What customers say</p>
      <h2 class="section-title">Trusted by the Industry</h2>
    </div>
    <div class="testimonials-track three-col">
      {% for item in testimonials %}{{ testimonialCard(item, "grid") }}{% endfor %}
    </div>
  </div>
</section>
{% include "components/testimonial-modal.njk" %}
{% include "components/cta-strip.njk" %}
<script>
  const s = document.getElementById("t-modal-overlay"),
    l = document.getElementById("t-modal-logo"),
    m = document.getElementById("t-modal-quote"),
    u = document.getElementById("t-modal-authors");
  function renderAuthor(a) {
    const headshot = a.headshot
      ? `<img src="${a.headshot}" alt="${a.name}" />`
      : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"></circle><path d="M4 20c0-4 3.5-6 8-6s8 2 8 6"></path></svg>`;
    return `<div class="t-modal-author"><div class="t-modal-headshot">${headshot}</div><div class="t-modal-author-info"><strong>${a.name}</strong><span>${a.role || ""}</span></div></div>`;
  }
  function y(e) {
    ((l.src = e.dataset.logo || ""), (l.alt = e.dataset.logoAlt || ""));
    m.innerHTML = e.dataset.quote || "";
    let authors = [];
    try {
      authors = JSON.parse(e.dataset.authors || "[]");
    } catch (err) {
      authors = [];
    }
    if (!authors.length) {
      u.innerHTML = "";
    } else if (authors.length === 1) {
      u.innerHTML = `<div class="t-modal-authors-row">${renderAuthor(authors[0])}</div>`;
    } else {
      const moreCount = authors.length - 1;
      u.innerHTML = `<div class="t-modal-authors-row">${renderAuthor(authors[0])}<button type="button" class="t-modal-more-toggle" data-expanded="false" data-more-label="+${moreCount} more" data-less-label="Show less">+${moreCount} more</button></div><div class="t-modal-authors-extra">${authors.slice(1).map(renderAuthor).join("")}</div>`;
    }
    s.classList.add("open");
    document.body.style.overflow = "hidden";
  }
  function n() {
    (s.classList.remove("open"), (document.body.style.overflow = ""));
  }
  u.addEventListener("click", (e) => {
    const btn = e.target.closest(".t-modal-more-toggle");
    if (!btn) return;
    const extra = u.querySelector(".t-modal-authors-extra");
    const expanded = btn.getAttribute("data-expanded") === "true";
    extra.style.display = expanded ? "none" : "flex";
    btn.textContent = expanded ? btn.dataset.moreLabel : btn.dataset.lessLabel;
    btn.setAttribute("data-expanded", expanded ? "false" : "true");
  });
  document.querySelectorAll(".btn-read-more").forEach((e) => {
    e.addEventListener("click", () => y(e.closest(".testimonial-card")));
  });
  document.getElementById("t-modal-close").addEventListener("click", n);
  s.addEventListener("click", (e) => {
    e.target === s && n();
  });
  document.addEventListener("keydown", (e) => {
    e.key === "Escape" && n();
  });
</script>
