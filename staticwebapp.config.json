{
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/features.html",
      "serve": "/features.html",
      "statusCode": 200
    },
    {
      "route": "/customers.html",
      "serve": "/customers.html",
      "statusCode": 200
    },
    {
      "route": "/integrations.html",
      "serve": "/integrations.html",
      "statusCode": 200
    },
    {
      "route": "/about.html",
      "serve": "/about.html",
      "statusCode": 200
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/features.html", "/customers.html", "/integrations.html", "/about.html"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "X-XSS-Protection": "1; mode=block",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".svg": "image/svg+xml",
    ".webp": "image/webp"
  }
}
